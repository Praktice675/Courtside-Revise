# Courtside — public Supabase environment contract
#
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Project Settings → API). `.env.local` is git-ignored and must never
# be committed.
#
# Both variables below are PUBLIC (`NEXT_PUBLIC_*`) and safe to expose in
# browser code. Never add a Supabase secret key, service-role key, database
# password, or connection string to this file or to any `NEXT_PUBLIC_*`
# variable — those belong only in trusted server-side configuration.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
